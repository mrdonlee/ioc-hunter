# =============================================================================
# IOC Hunter — environment configuration
# =============================================================================
# Copy this file to `.env` and fill in your keys.
# Run `ioc-hunter configure` for an interactive setup wizard.
#
# All keys are OPTIONAL — sources without keys are skipped at runtime
# with a warning, the rest still work.
# =============================================================================

# AbuseIPDB — IP reputation
# Free tier: 1000 lookups/day. Register at https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=

# AlienVault OTX — multi-type IOC pulses and reputation
# Free, no quota. Register at https://otx.alienvault.com/
OTX_API_KEY=

# VirusTotal — file/URL/IP/domain reputation
# Free public API: 4 req/min, 500/day. Register at https://www.virustotal.com/
VIRUSTOTAL_API_KEY=

# Shodan (optional) — exposed services on IPs
# Free tier limited. Register at https://account.shodan.io/register
SHODAN_API_KEY=

# -----------------------------------------------------------------------------
# Runtime configuration
# -----------------------------------------------------------------------------

# Cache TTL in seconds (default 24h)
IOC_CACHE_TTL=86400

# Cache directory (created if missing)
IOC_CACHE_DIR=./cache

# Log level: DEBUG, INFO, WARNING, ERROR
IOC_LOG_LEVEL=INFO

# Concurrent source queries per IOC (default 8)
IOC_MAX_CONCURRENCY=8
